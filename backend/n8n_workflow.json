          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "fact-check-node",
      "name": "Fact-Check Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [550, 300],
      "credentials": {}
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8000/source-score",
        "jsonParameters": true,
        "options": {
