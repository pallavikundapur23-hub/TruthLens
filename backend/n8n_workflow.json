      "name": "AI Detection Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [550, 150],
      "credentials": {}
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8000/fact-check",
        "jsonParameters": true,
        "options": {
          "timeout": 30
        },
